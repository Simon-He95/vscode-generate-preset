{
  "publisher": "simonhe",
  "name": "vscode-generate-preset",
  "displayName": "vscode generate preset",
  "version": "0.0.15",
  "packageManager": "pnpm@9.15.9",
  "description": "vscode-generate-preset",
  "author": "Simon He <https://github.com/Simon-He95>",
  "license": "MIT",
  "funding": "https://github.com/sponsors/Simon-He95",
  "homepage": "https://github.com/Simon-He95/vscode-generate-preset#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/Simon-He95/vscode-generate-preset"
  },
  "bugs": {
    "url": "https://github.com/Simon-He95/vscode-generate-preset/issues"
  },
  "sponsor": {
    "url": "https://github.com/Simon-He95/sponsor"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/index.js",
  "icon": "icon.png",
  "files": [
    "LICENSE",
    "dist",
    "icon.png"
  ],
  "engines": {
    "vscode": "^1.95.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "menus": {
      "explorer/context": [
        {
          "group": "editor",
          "submenu": "generate-preset"
        }
      ],
      "generate-preset": [
        {
          "command": "vscode-generate-preset.run",
          "when": "explorerResourceIsFolder"
        },
        {
          "command": "vscode-generate-preset.add"
        },
        {
          "command": "vscode-generate-preset.delete"
        }
      ]
    },
    "submenus": [
      {
        "id": "generate-preset",
        "label": "Preset"
      }
    ],
    "commands": [
      {
        "command": "vscode-generate-preset.run",
        "title": "Select Preset"
      },
      {
        "command": "vscode-generate-preset.add",
        "title": "Add Preset"
      },
      {
        "command": "vscode-generate-preset.delete",
        "title": "Delete Preset"
      }
    ]
  },
  "scripts": {
    "dev": "pnpm build --watch",
    "test": "vitest run",
    "build": "tsup src/index.ts --external vscode",
    "pack": "pnpm build && vsce package --no-dependencies",
    "lint": "eslint . --cache",
    "lint:fix": "pnpm lint --fix",
    "publish": "pnpm build && vsce publish --no-dependencies",
    "typecheck": "tsc --noEmit",
    "release": "bumpp && pnpm run publish"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.27.3",
    "@types/node": "^18.19.64",
    "@types/vscode": "^1.95.0",
    "@vscode-use/utils": "0.1.36",
    "@vscode/vsce": "^3.9.1",
    "bumpp": "^9.8.1",
    "eslint": "^8.57.1",
    "esno": "^0.16.3",
    "json5": "^2.2.3",
    "pnpm": "^9.15.9",
    "rimraf": "^4.4.1",
    "tsup": "^6.7.0",
    "typescript": "^5.6.3",
    "vitest": "^0.29.8"
  }
}
